# Formspree setup
# Create one Formspree form for Contact and one for Membership, then paste the
# form IDs below. Example endpoint: https://formspree.io/f/xyzabcde -> form ID is xyzabcde

NEXT_PUBLIC_FORMSPREE_CONTACT_FORM_ID=your-contact-form-id
NEXT_PUBLIC_FORMSPREE_MEMBERSHIP_FORM_ID=your-membership-form-id

# Optional fallback if you want both forms to use the same Formspree inbox.
# NEXT_PUBLIC_FORMSPREE_ID=your-shared-form-id

# Decap CMS GitHub OAuth for Vercel deployment
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# Optional: use `repo,user` for private repositories, `public_repo,user` for public repositories.
# GITHUB_OAUTH_SCOPE=repo,user
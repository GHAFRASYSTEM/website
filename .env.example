# Public Formspree form ID used by the contact and membership forms.
NEXT_PUBLIC_FORMSPREE_CONTACT_FORM_ID=
NEXT_PUBLIC_FORMSPREE_MEMBERSHIP_FORM_ID=

# CMS OAuth settings for Decap CMS auth routes.
# These are used by the GitHub OAuth routes that power Decap CMS on Vercel.
CMS_GITHUB_CLIENT_ID=
CMS_GITHUB_CLIENT_SECRET=
CMS_OAUTH_AUTHORIZE_URL=https://www.ghafra.com/api/cms/oauth/authorize
CMS_OAUTH_CALLBACK_URL=https://www.ghafra.com/api/cms/oauth/callback
